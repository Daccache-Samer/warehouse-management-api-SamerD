@page
@{
    ViewData["Title"] = "Access Denied";
}

<div class="container text-center mt-5">
    <div class="card p-5 shadow-sm border-danger">
        <h1 class="text-danger mb-3">Unauthenticated Page</h1>
        <p class="lead text-muted">Uh oh! It looks like you aren't authenticated with Firebase.</p>
        <hr />
        <p>Please log in or create an account to view this content.</p>
        <div class="mt-3">
            <a href="/Login" class="btn btn-primary me-2">Log In</a>
            <a href="/SignUp" class="btn btn-secondary">Sign Up</a>
        </div>
    </div>
</div>